<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup and device-transfer exclusion rules.
     Mirrors backup_rules.xml for the pre-12 cloud-backup path. -->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="database" path="contextreply.db" />
    <exclude domain="database" path="contextreply.db-shm" />
    <exclude domain="database" path="contextreply.db-wal" />
  </cloud-backup>
  <device-transfer>
    <exclude domain="database" path="contextreply.db" />
    <exclude domain="database" path="contextreply.db-shm" />
    <exclude domain="database" path="contextreply.db-wal" />
  </device-transfer>
</data-extraction-rules>
