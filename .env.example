# ── Cloudflare Worker (production) ───────────────────────────────────────────
# Deploy worker/ with wrangler, then paste the URL here.
# When set, the app calls the Worker instead of Claude directly (API key stays server-side).
EXPO_PUBLIC_WORKER_URL=https://contextreply-suggest.<your-subdomain>.workers.dev

# ── Claude (local dev only — not needed once Worker is deployed) ──────────────
# Remove this from EAS env — it's dead code now that the Worker handles Claude.
# https://console.anthropic.com → Settings → API Keys
# EXPO_PUBLIC_CLAUDE_API_KEY=your_claude_api_key_here

# ── Google Maps Directions API ────────────────────────────────────────────────
# https://console.cloud.google.com → Enable "Directions API" → Credentials
# Restrict to this app's Android SHA-1 fingerprint in GCP Console.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Fallback destination used for ETA until the user saves a Work place in-app.
# Accepts addresses ("1 Infinite Loop, Cupertino, CA") or lat,lng ("37.33,-122.03")
# EXPO_PUBLIC_MAPS_DESTINATION=51.5033,-0.0865

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=your_web_client_id_here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=your_ios_client_id_here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=your_android_client_id_here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CALENDAR_ID=primary
