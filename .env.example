# ── Claude ───────────────────────────────────────────────────────────────────
# https://console.anthropic.com → Settings → API Keys
EXPO_PUBLIC_CLAUDE_API_KEY=your_claude_api_key_here

# ── Google Maps Directions API ────────────────────────────────────────────────
# https://console.cloud.google.com → Enable "Directions API" → Credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Hardcoded journey: edit these to match your real use-case
# Accepts addresses ("1 Infinite Loop, Cupertino, CA") or lat,lng ("37.33,-122.03")
EXPO_PUBLIC_MAPS_ORIGIN=51.5074,-0.1278
EXPO_PUBLIC_MAPS_DESTINATION=51.5033,-0.0865

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# https://developers.google.com/oauthplayground
# Scope: https://www.googleapis.com/auth/calendar.readonly
# NOTE: access tokens expire in ~1 hour; refresh manually for now (Sprint 2 adds OAuth flow)
EXPO_PUBLIC_GOOGLE_CALENDAR_ACCESS_TOKEN=your_oauth_access_token_here
EXPO_PUBLIC_GOOGLE_CALENDAR_ID=primary
