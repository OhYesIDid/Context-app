{
  "expo": {
    "name": "ConTxt",
    "slug": "context-reply",
    "scheme": "contxt",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/contxt-logo-g-minimal-circuit.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.contxt.app",
      "icon": "./assets/contxt-logo-g-minimal-circuit.png"
    },
    "android": {
      "package": "com.contxt.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-share-extension",
        {
          "activationRules": [
            {
              "type": "text"
            },
            {
              "type": "url",
              "max": 1
            }
          ],
          "height": 480,
          "backgroundColor": {
            "red": 12,
            "green": 12,
            "blue": 14,
            "alpha": 1
          },
          "excludedPackages": [
            "expo-splash-screen",
            "expo-updates"
          ]
        }
      ],
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ConTxt to check your location for ETA replies."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "191da8c5-ddf6-4ae8-86fe-b39d8eb1ecb5"
      }
    },
    "owner": "ohyesidid"
  }
}
