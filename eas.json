{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview-ios-sim": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {}

  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./android/play-store-key.json",
        "track": "internal"
      }
    }
  }
}
